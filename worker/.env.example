# Copier en .dev.vars pour le développement local Wrangler
# NE JAMAIS committer avec de vraies valeurs !

# ── Airtel CG API ─────────────────────────────────────────────
# Depuis https://developers.airtel.cg (ou openapiuat.airtel.cg pour les tests)
AIRTEL_CLIENT_ID=ton_client_id_ici
AIRTEL_CLIENT_SECRET=ton_client_secret_ici

# Ton PIN Airtel Money EN CLAIR (ex: 1234 ou le PIN de ton compte)
# Le chiffrement RSA avec la clé publique Airtel est automatique dans le code.
# x-signature et x-key sont générés dynamiquement — rien à configurer manuellement.
AIRTEL_PIN=ton_pin_en_clair_ici

# ── Config ────────────────────────────────────────────────────
AIRTEL_BASE_URL=https://openapiuat.airtel.cg
AIRTEL_COUNTRY_CODE=CG
AIRTEL_CURRENCY=XAF

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET=change_moi_minimum_32_caracteres_aleatoires

ENVIRONMENT=development
